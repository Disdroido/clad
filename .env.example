# Database (Neon Postgres)
NEON_DATABASE_URL=postgresql://user:pass@ep-xxx.region.neon.tech/clad?sslmode=require

# OpenRouter (for AI - both vision and text models)
OPENROUTER_API_KEY=sk-or-xxx

# Cloudflare R2 (image storage)
# Production Workers use the R2_IMAGES binding (see wrangler.jsonc) — no token needed.
# R2_API_TOKEN is only for local `nuxt dev` without Wrangler emulation. Use an Account API
# token (Dashboard → My Profile → API Tokens) with Account → R2 → Edit — NOT an R2 S3 key.
# R2_PUBLIC_URL is the bucket's public r2.dev URL or custom domain (required for AI vision).
R2_ACCOUNT_ID=xxx
R2_API_TOKEN=cfat_xxx
R2_BUCKET_NAME=clad-images
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Auth
AUTH_SECRET=generate-a-random-secret-with-openssl-rand-base64-32

# WeatherAPI.com (for real-time weather in outfit generation)
# Sign up at https://www.weatherapi.com/ — Free tier: 100K calls/month
NUXT_WEATHER_API_KEY=your-weatherapi-key-here

# Public (must include https:// in production, e.g. https://clad.example.workers.dev)
PUBLIC_APP_URL=http://localhost:3000

# --- Cloudflare Workers production ---
# Set these in the Cloudflare dashboard (Settings → Variables and Secrets),
# NOT in wrangler.jsonc. NUXT_* names also work if you prefer Nuxt's convention.
#
# Secrets (encrypted):
#   AUTH_SECRET, NEON_DATABASE_URL, OPENROUTER_API_KEY
# Plain text vars:
#   PUBLIC_APP_URL=https://your-app.workers.dev
#   R2_PUBLIC_URL (must match your bucket's public URL)
# R2 binding is configured in wrangler.jsonc — redeploy after changing bucket name.
